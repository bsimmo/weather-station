# MQTT Weather Station Configuration
# Copy this file to mqtt.env and customize for your setup
# Load with: export $(cat mqtt.env | xargs) && python3 mqtt.py

# MQTT Broker Configuration
MQTT_SERVER=mqtt.example.com
MQTT_PORT=1883

# MQTT Authentication (optional - leave empty for anonymous)
MQTT_USERNAME=
MQTT_PASSWORD=

# Client Configuration
MQTT_CLIENT_ID=weatherhat
MQTT_TOPIC_PREFIX=sensors

# Sensor Configuration
# Temperature offset to compensate for Pi heat
TEMP_OFFSET=-7.5

# Update intervals in seconds
UPDATE_INTERVAL=2.0
PUBLISH_INTERVAL=2.0

# Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
